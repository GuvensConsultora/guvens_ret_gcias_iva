<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Certificado de retención IIBB/Ganancias compacto (1 hoja).
             Datos obligatorios según normativa ARBA. -->

        <template id="report_withholding_certificate_document">
            <t t-call="web.external_layout">
                <t t-set="o" t-value="o.with_context(lang=lang)"/>

                <div class="page" style="font-family: Arial, sans-serif; font-size: 10px; color: #333;">

                    <!-- ═══ ENCABEZADO ═══ -->
                    <div style="text-align: center; margin: 8px 0;">
                        <div style="font-size: 14px; font-weight: bold; letter-spacing: 1px;">CERTIFICADO DE RETENCIÓN</div>
                        <div style="font-size: 11px; color: #555;"><t t-esc="o.get_withholding_type_label()"/></div>
                    </div>

                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 6px;">
                        <tr>
                            <td style="text-align: center; padding: 3px; border: 1px solid #999; width: 50%;">
                                <strong>Nro. Certificado:</strong>
                                <span t-if="o.withholding_number" t-field="o.withholding_number"/>
                                <span t-else="" t-field="o.name"/>
                            </td>
                            <td style="text-align: center; padding: 3px; border: 1px solid #999; width: 50%;">
                                <strong>Fecha:</strong> <span t-field="o.date"/>
                            </td>
                        </tr>
                    </table>

                    <!-- ═══ AGENTE DE RETENCIÓN ═══ -->
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 6px;">
                        <tr>
                            <td colspan="2" style="background: #d6d8db; padding: 3px 6px; font-weight: bold; border: 1px solid #999; font-size: 10px;">
                                AGENTE DE RETENCIÓN
                            </td>
                        </tr>
                        <tr>
                            <td style="width: 50%; padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>Razón Social:</strong> <span t-field="o.company_id.name"/>
                            </td>
                            <td style="width: 50%; padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>CUIT:</strong> <span t-field="o.company_id.vat"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>Cond. IVA:</strong> <span t-field="o.company_id.partner_id.l10n_ar_afip_responsibility_type_id"/>
                            </td>
                            <td style="padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>Inicio Act.:</strong> <span t-field="o.company_id.l10n_ar_afip_start_date"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>Domicilio:</strong>
                                <span t-field="o.company_id.partner_id.street"/>
                                <t t-if="o.company_id.partner_id.street2"> - <span t-field="o.company_id.partner_id.street2"/></t>,
                                <span t-field="o.company_id.partner_id.city"/>
                                <t t-if="o.company_id.partner_id.state_id"> - <span t-field="o.company_id.partner_id.state_id"/></t>
                                <t t-if="o.company_id.partner_id.zip"> (<span t-field="o.company_id.partner_id.zip"/>)</t>
                            </td>
                            <td style="padding: 2px 6px; border: 1px solid #ccc;">
                                <t t-if="o.is_iibb_withholding()">
                                    <strong>Nro. IIBB:</strong> <span t-field="o.company_id.l10n_ar_gross_income_number"/>
                                </t>
                                <t t-if="o.is_ganancias_withholding()">
                                    <strong>Régimen:</strong> <span t-esc="o.get_regimen_ganancias_label()"/>
                                </t>
                            </td>
                        </tr>
                    </table>

                    <!-- ═══ SUJETO RETENIDO ═══ -->
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 6px;">
                        <tr>
                            <td colspan="2" style="background: #d6d8db; padding: 3px 6px; font-weight: bold; border: 1px solid #999; font-size: 10px;">
                                SUJETO RETENIDO
                            </td>
                        </tr>
                        <tr>
                            <td style="width: 50%; padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>Razón Social:</strong> <span t-field="o.partner_id.commercial_partner_id.name"/>
                            </td>
                            <td style="width: 50%; padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>CUIT:</strong> <span t-field="o.partner_id.commercial_partner_id.vat"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>Cond. IVA:</strong> <span t-field="o.partner_id.commercial_partner_id.l10n_ar_afip_responsibility_type_id"/>
                            </td>
                            <td style="padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>Nro. IIBB:</strong>
                                <t t-if="o.partner_id.commercial_partner_id.l10n_ar_gross_income_number">
                                    <span t-field="o.partner_id.commercial_partner_id.l10n_ar_gross_income_number"/>
                                </t>
                                <t t-else="">-</t>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" style="padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>Domicilio:</strong>
                                <span t-field="o.partner_id.commercial_partner_id.street"/>
                                <t t-if="o.partner_id.commercial_partner_id.street2"> - <span t-field="o.partner_id.commercial_partner_id.street2"/></t>,
                                <span t-field="o.partner_id.commercial_partner_id.city"/>
                                <t t-if="o.partner_id.commercial_partner_id.state_id"> - <span t-field="o.partner_id.commercial_partner_id.state_id"/></t>
                                <t t-if="o.partner_id.commercial_partner_id.zip"> (<span t-field="o.partner_id.commercial_partner_id.zip"/>)</t>
                            </td>
                        </tr>
                    </table>

                    <!-- ═══ DETALLE DE LA RETENCIÓN ═══ -->
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 6px;">
                        <tr>
                            <td colspan="2" style="background: #d6d8db; padding: 3px 6px; font-weight: bold; border: 1px solid #999; font-size: 10px;">
                                DETALLE DE LA RETENCIÓN
                            </td>
                        </tr>
                        <tr>
                            <td style="width: 50%; padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>Impuesto:</strong> <span t-field="o.tax_withholding_id"/>
                            </td>
                            <td style="width: 50%; padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>Régimen:</strong>
                                <t t-if="o.is_iibb_withholding()">Régimen General - IIBB Prov. Buenos Aires</t>
                                <t t-if="o.is_ganancias_withholding()"><span t-esc="o.get_regimen_ganancias_label()"/></t>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>Fecha Retención:</strong> <span t-field="o.date"/>
                            </td>
                            <td style="padding: 2px 6px; border: 1px solid #ccc;">
                                <strong>Nro. Comprobante Pago:</strong>
                                <t t-if="o.payment_group_id"><span t-field="o.payment_group_id.display_name"/></t>
                            </td>
                        </tr>
                    </table>

                    <!-- ═══ LIQUIDACIÓN ═══ -->
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 6px;">
                        <tr>
                            <td colspan="3" style="background: #d6d8db; padding: 3px 6px; font-weight: bold; border: 1px solid #999; font-size: 10px;">
                                LIQUIDACIÓN
                            </td>
                        </tr>
                        <tr style="text-align: center; font-weight: bold; background: #f0f0f0;">
                            <td style="width: 33%; padding: 3px; border: 1px solid #ccc;">Base Imponible</td>
                            <td style="width: 33%; padding: 3px; border: 1px solid #ccc;">Alícuota</td>
                            <td style="width: 34%; padding: 3px; border: 1px solid #ccc;">Importe Retenido</td>
                        </tr>
                        <tr style="text-align: center; font-size: 12px;">
                            <td style="padding: 5px; border: 1px solid #ccc;">
                                <span t-field="o.withholdable_base_amount"
                                      t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                            </td>
                            <td style="padding: 5px; border: 1px solid #ccc;">
                                <t t-set="alicuota" t-value="o.get_withholding_alicuota()"/>
                                <t t-if="alicuota == -1">Según escala</t>
                                <t t-else=""><span t-esc="'{:.2f} %'.format(alicuota)"/></t>
                            </td>
                            <td style="padding: 5px; border: 1px solid #ccc; font-weight: bold;">
                                <span t-field="o.amount"
                                      t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                            </td>
                        </tr>
                    </table>

                    <!-- ═══ COMPROBANTES ═══ -->
                    <t t-set="invoices" t-value="o.get_withholding_invoices()"/>
                    <t t-if="invoices">
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 6px;">
                            <tr>
                                <td colspan="5" style="background: #d6d8db; padding: 3px 6px; font-weight: bold; border: 1px solid #999; font-size: 10px;">
                                    COMPROBANTES QUE ORIGINAN LA RETENCIÓN
                                </td>
                            </tr>
                            <tr style="background: #f0f0f0; text-align: center; font-size: 9px;">
                                <th style="padding: 2px; border: 1px solid #ccc;">Fecha</th>
                                <th style="padding: 2px; border: 1px solid #ccc;">Comprobante</th>
                                <th style="padding: 2px; border: 1px solid #ccc;">Referencia</th>
                                <th style="padding: 2px; border: 1px solid #ccc; text-align: right;">Importe</th>
                                <th style="padding: 2px; border: 1px solid #ccc; text-align: right;">Saldo</th>
                            </tr>
                            <t t-foreach="invoices" t-as="inv">
                                <tr style="font-size: 9px;">
                                    <td style="padding: 2px 4px; border: 1px solid #ccc; text-align: center;">
                                        <span t-field="inv.invoice_date"/>
                                    </td>
                                    <td style="padding: 2px 4px; border: 1px solid #ccc;">
                                        <span t-field="inv.name"/>
                                    </td>
                                    <td style="padding: 2px 4px; border: 1px solid #ccc;">
                                        <span t-field="inv.ref"/>
                                    </td>
                                    <td style="padding: 2px 4px; border: 1px solid #ccc; text-align: right;">
                                        <span t-field="inv.amount_total" t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}"/>
                                    </td>
                                    <td style="padding: 2px 4px; border: 1px solid #ccc; text-align: right;">
                                        <span t-field="inv.amount_residual" t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}"/>
                                    </td>
                                </tr>
                            </t>
                        </table>
                    </t>

                    <!-- ═══ OBSERVACIONES ═══ -->
                    <t t-if="o.communication">
                        <div style="border: 1px solid #ccc; padding: 3px 6px; margin-bottom: 6px;">
                            <strong>Observaciones:</strong> <span t-field="o.communication"/>
                        </div>
                    </t>

                    <!-- ═══ FIRMA ═══ -->
                    <div style="margin-top: 30px; text-align: right; padding-right: 30px;">
                        <div style="display: inline-block; text-align: center; width: 220px;">
                            <div style="border-top: 1px solid #333; padding-top: 3px; margin-top: 40px; font-size: 9px;">
                                Firma y Sello del Agente de Retención
                            </div>
                        </div>
                    </div>

                    <!-- ═══ PIE LEGAL ═══ -->
                    <div style="margin-top: 10px; font-size: 8px; color: #999; text-align: center;">
                        Este certificado debe ser conservado por el sujeto retenido como constancia de la retención practicada.
                        Original para el retenido / Duplicado para el agente de retención.
                    </div>

                </div>
            </t>
        </template>

        <!-- Template wrapper -->
        <template id="report_withholding_certificate">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="guvens_ret_gcias_iva.report_withholding_certificate_document"
                       t-lang="o.partner_id.lang"/>
                </t>
            </t>
        </template>

        <!-- Override del report action OCA -->
        <record id="l10n_ar_report_withholding.action_payment_withholdings" model="ir.actions.report">
            <field name="report_name">guvens_ret_gcias_iva.report_withholding_certificate</field>
            <field name="report_file">guvens_ret_gcias_iva.report_withholding_certificate</field>
            <field name="print_report_name">'Certificado Retención - %s' % (object.withholding_number or object.name)</field>
        </record>

    </data>
</odoo>
