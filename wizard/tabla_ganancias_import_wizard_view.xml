<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="tabla_ganancias_import_wizard_form" model="ir.ui.view">
        <field name="name">tabla.ganancias.import.wizard.form</field>
        <field name="model">tabla.ganancias.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Actualizar Escala de Ganancias">
                <group>
                    <field name="mes" widget="radio"/>
                </group>
                <separator string="Escala Art. 94 LIG — Acumulada mensual"/>
                <p>Calcula los 9 tramos acumulados para el mes seleccionado
                   a partir de la escala anual 2026 (ARCA).</p>
                <footer>
                    <button name="action_actualizar_escala"
                            string="Actualizar escala"
                            type="object" class="btn-primary"/>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_tabla_ganancias_import" model="ir.actions.act_window">
        <field name="name">Actualizar Escala Ganancias</field>
        <field name="res_model">tabla.ganancias.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_tabla_ganancias_import"
        name="Actualizar Escala Ganancias"
        parent="account.account_management_menu"
        action="action_tabla_ganancias_import"
        sequence="99"/>

</odoo>
